<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Saurabh Giri Business Tycoon</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#222;
color:white;
text-align:center;
}

header{
background:#111;
padding:20px;
font-size:30px;
font-weight:bold;
color:#FFD700;
}

#money{
font-size:28px;
margin-top:20px;
}

#business{
margin-top:20px;
}

img{
width:250px;
border-radius:12px;
}

button{
margin:10px;
padding:15px 25px;
font-size:20px;
background:#28a745;
color:white;
border:none;
border-radius:10px;
cursor:pointer;
}

button:hover{
background:#1d7d33;
}

#level{
font-size:24px;
margin-top:15px;
}
</style>
</head>

<body>

<header>
SAURABH GIRI BUSINESS TYCOON
</header>

<div id="money">
💰 Money: ₹<span id="cash">100</span>
</div>

<div id="level">
Business: Tea Stall
</div>

<div id="business">
<img src="tea_stall.jpg" alt="Tea Stall">
</div>

<button onclick="earn()">
Sell Tea (+₹10)
</button>

<button onclick="upgrade()">
Upgrade Business
</button>

<script>

let money=100;
let level=0;

const business=[
"Tea Stall",
"Cafe",
"Restaurant",
"Hotel"
];

function earn(){
money+=10+(level*20);
document.getElementById("cash").innerHTML=money;
}

function upgrade(){

if(level==0 && money>=500){
money-=500;
level=1;
}

else if(level==1 && money>=2000){
money-=2000;
level=2;
}

else if(level==2 && money>=10000){
money-=10000;
level=3;
}

document.getElementById("cash").innerHTML=money;
document.getElementById("level").innerHTML="Business: "+business[level];

}

setInterval(function(){

money+=5+(level*10);

document.getElementById("cash").innerHTML=money;

},1000);

</script>

</body>
</html>
